DIRECTUS_URL=
#SMTP server hostname, for example smtp.your-provider.tld
SMTP_URL=
#optional single connection string instead of the separate host/user/pass values
SMTP_HOST=
#usually 587 or 465
SMTP_PORT=587
#true for implicit SSL (465), false for STARTTLS (587)
SMTP_SECURE=false
#SMTP login username
SMTP_USER=
#SMTP password or app password
SMTP_PASS=
#sender address, for example website@yourdomain.de
SMTP_FROM=
#inbox that should receive the form mails
SMTP_TO=moin@ow-norderstedt.de

#how to get
#provider admin panel:
 #SMTP settings
 #Outgoing mail
 #SMTP relay
 #App passwords
 #Developer / API / SMTP credentials
